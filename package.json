{
  "name": "playwright-bdd-boilerplate",
  "version": "1.0.0",
  "description": "",
  "keywords": [
    "Playwright",
    "BDD",
    "Cucumber",
    "Page Object Model",
    "Fixtures"
  ],
  "author": "serhat.gemici",
  "license": "ISC",
  "imports": {
    "#e2e/*": "./e2e/*"
  },
  "type": "module",
  "scripts": {
    "open:local:watch": "run-p watch open:local",
    "open:dev:watch": "run-p watch open:dev",
    "open:stage:watch": "run-p watch open:stage",
    "open:prod:watch": "run-p watch open:prod",
    "test:local": "run-s -c delete:allure:results bddgen env:local",
    "test:dev": "run-s -c delete:allure:results bddgen env:dev",
    "test:stage": "run-s -c delete:allure:results bddgen env:stage",
    "test:prod": "run-s -c delete:allure:results bddgen env:prod",
    "test:local:report": "run-s -c test:local allure",
    "test:dev:report": "run-s -c test:dev allure",
    "test:stage:report": "run-s -c test:stage allure",
    "test:prod:report": "run-s -c test:prod allure",
    "open:local": "playwright test --ui --project=Local",
    "open:dev": "playwright test --ui --project=Develop",
    "open:stage": "playwright test --ui --project=Stage",
    "open:prod": "playwright test --ui --project=Production",
    "watch": "nodemon -w ./e2e/Features -w ./e2e/StepDefinitions -e ts,feature --exec \"npx bddgen\"",
    "bddgen": "npx bddgen",
    "allure": "allure generate allure-results -o allure-report --clean && allure open",
    "delete:allure:results": "npx del-cli allure-results",
    "env:local": "playwright test --project=Local",
    "env:dev": "playwright test --project=Develop",
    "env:stage": "playwright test --project=Stage",
    "env:prod": "playwright test --project=Production",
    "lint": "eslint 'e2e/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'e2e/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'e2e/**/*.{ts,tsx,js,jsx,json,md}'"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.3",
    "allure-playwright": "^3.10.0",
    "del-cli": "^7.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "playwright-bdd": "^9.1.0",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.0"
  }
}
