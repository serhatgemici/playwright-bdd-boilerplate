{
  "name": "intellij-assignment",
  "version": "1.0.0",
  "description": "",
  "keywords": [
    "Playwright",
    "Page Object Model",
    "Page Factory Pattern",
    "Fixtures"
  ],
  "author": "serhat.gemici",
  "license": "ISC",
  "imports": {
    "#e2e/*": "./e2e/*"
  },
  "type": "module",
  "scripts": {
    "test:dev": "run-s -c delete:allure:results cross:env:dev",
    "test:stage": "run-s -c delete:allure:results cross:env:stage",
    "test:local": "run-s -c delete:allure:results cross:env:local",
    "test:dev:report": "run-s -c test:dev allure",
    "test:stage:report": "run-s -c test:stage allure",
    "test:local:report": "run-s -c test:local allure",
    "open:local": "playwright test --ui --project=Local",
    "open:dev": "playwright test --ui --project=Develop",
    "open:stage": "playwright test --ui --project=Stage",
    "allure": "allure generate allure-results -o allure-report --clean && allure open",
    "delete:allure:results": "npx del-cli allure-results",
    "cross:env:dev": "cross-env playwright test --project=Develop",
    "cross:env:stage": "cross-env playwright test --project=Stage",
    "cross:env:local": "cross-env playwright test --project=Local",
    "lint": "eslint 'e2e/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'e2e/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'e2e/**/*.{ts,tsx,js,jsx,json,md}'"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "@types/node": "^24.8.0",
    "allure-playwright": "^3.4.1",
    "cross-env": "^10.1.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "npm-run-all": "^4.1.5",
    "playwright-bdd": "^8.5.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.46.2"
  }
}
