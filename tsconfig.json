{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "strict": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "paths": {
      "#e2e/*": ["./e2e/*"],
      "#utils/*": ["./e2e/utils/*"]
    }
  },
  "include": ["**/*.ts"]
}
